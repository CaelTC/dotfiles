#!/usr/bin/env zsh
# cca — launch a HUMAN's interactive `claude` behind a per-Session capture Proxy.
#
# The human+force-auto caller of the shared capture lifecycle: it tags the
# Session's Origin as Human and forces `--permission-mode auto` (evolved from the
# `claude --permission-mode auto` alias). Its agent-session sibling is `cc`
# (Origin=Agent, args passed straight through). Both source the same
# lib/cca-capture.sh so the capture lifecycle lives in one place.
#
# Install: build the binary (`cargo build --release`) and put both `claude-dash`
# and this script on PATH, e.g.
#   ln -s "$PWD/target/release/claude-dash" ~/.local/bin/claude-dash
#   ln -s "$PWD/bin/cca"                     ~/.local/bin/cca
# Then launch Claude Code with `cca` in place of `claude` (alias claude=cca if you
# like). cca finds `claude-dash` via $CLAUDE_DASH_BIN or PATH.

emulate -L zsh
set -u

_cca_prog=cca
_cca_origin=human
_cca_perm=force-auto
source "${0:A:h}/lib/cca-capture.sh"
