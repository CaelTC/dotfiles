{
  "permissions": {
    "allow": [
      "Bash(ghostty +list-themes)",
      "Bash(ghostty +list-fonts)",
      "Bash(ghostty +show-config *)",
      "Bash(ghostty +validate-config *)",
      "Read(~/.config/ghostty/**)",
      "Bash(cargo --version)",
      "Bash(cargo init *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo test *)"
    ]
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "warp@claude-code-warp": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "editorMode": "vim",
  "voiceEnabled": true,
  "worktree": {
    "baseRef": "head"
  }
}
