{
  "statusLine": {
    "type": "command",
    "command": "sh /Users/macbook/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "warp@claude-code-warp": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "effortLevel": "xhigh",
  "advisorModel": "opus",
  "editorMode": "vim",
  "permissions": {
    "allow": [
      "Bash(ghostty +list-themes)",
      "Bash(ghostty +list-fonts)",
      "Bash(ghostty +show-config *)",
      "Bash(ghostty +validate-config *)",
      "Read(/Users/macbook/.config/ghostty/**)",
      "Bash(cargo --version)",
      "Bash(cargo init *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo test *)"
    ]
  }
}
